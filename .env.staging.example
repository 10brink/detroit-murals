# Staging config — copy to .env.staging and fill in your values
#
# Neon branch setup:
#   1. Open Neon Console → your project → Branches
#   2. Click "Create branch" from main
#   3. Copy the connection string for the new branch
#
# Cloudinary staging preset:
#   1. Open Cloudinary Console → Settings → Upload
#   2. Add a new Upload Preset (unsigned), name it e.g. detroit-murals-staging
#   3. Set the folder to "detroit-murals-staging" in the preset config

NODE_ENV=staging
PORT=3001

DATABASE_URL=postgresql://user:password@staging-branch-host/dbname?sslmode=require
PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_staging_unsigned_preset
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
ADMIN_PASSWORD=your_admin_password_here
